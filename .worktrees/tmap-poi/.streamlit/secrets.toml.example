# 이 파일을 같은 폴더에 secrets.toml 로 복사한 뒤 실제 앱키를 넣으세요.
# secrets.toml 은 .gitignore 에 등록되어 있어 GitHub에 올라가지 않습니다.
#
# Streamlit Cloud 배포 시에는 이 파일 대신
# 앱 대시보드 → Settings → Secrets 에 아래 줄들을 그대로 붙여넣으면 됩니다.

# TMAP 앱키(권장) — 보행자 경로·대중교통·장소 검색(POI)·현재위치 주소표시에 함께 사용.
# SK open API 콘솔(대시보드→앱)에서 각 상품(보행자 경로/대중교통/POI 통합검색/
# Reverse Geocoding)을 활성화해야 해당 기능이 켜집니다.
# 키·상품이 없으면 무료 대체(Valhalla/Nominatim)로 자동 전환되어 앱은 계속 동작합니다.
TMAP_APP_KEY = "여기에_TMAP_앱키_입력"

# 대중교통 경로(선택) — "대중교통 포함" 여정에 지하철·버스 구간을 넣으려면 필요합니다.
# 우선순위: TMAP transit(위 TMAP_APP_KEY에 SK open API 콘솔에서 '대중교통' 상품 활성화)
#   → ODsay(https://lab.odsay.com 무료 발급) → 둘 다 없으면 도보 전용으로 자동 전환.
ODSAY_API_KEY = "여기에_ODsay_API키_입력"

# 주소·장소 검색(권장) — Streamlit Cloud에서는 이 키가 있어야 검색이 안정적으로 동작합니다.
# (키가 없으면 Nominatim(OSM)으로 폴백하는데, 클라우드 공용 IP는 차단·제한될 수 있어
#  '합정동·합정역'처럼 흔한 검색도 실패할 수 있습니다.)
# Naver Cloud Platform → Maps → Geocoding 에서 발급한 값:
NAVER_MAPS_CLIENT_ID = "여기에_NAVER_CLIENT_ID_입력"
NAVER_MAPS_CLIENT_SECRET = "여기에_NAVER_CLIENT_SECRET_입력"
