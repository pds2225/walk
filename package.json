{
  "name": "walk",
  "version": "1.0.0",
  "private": true,
  "description": "Pedestrian route deviation detection engine for walking navigation",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "simulate": "tsx packages/route-engine/src/simulator/runSimulator.ts",
    "web:install": "python -m pip install -r streamlit_walk_engine/requirements.txt",
    "web:demo": "python -m streamlit run streamlit_walk_engine/app.py"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  }
}
